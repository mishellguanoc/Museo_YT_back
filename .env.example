# Base de datos - Supabase PostgreSQL
DATABASE_URL="postgresql://usuario:password@db.tuproyecto.supabase.co:5432/postgres?schema=public"

# Configuración de la aplicación
PORT=3000
NODE_ENV=development

# JWT Secret para autenticación
JWT_SECRET="tu-clave-secreta-super-segura-cambiar-en-produccion"

# Configuración de correo electrónico (Gmail como ejemplo)
